# ===========================================
# BACKEND - DASHBOARD ORÇAMENTO v2.0
# ===========================================

# Server
PORT=3001
NODE_ENV=development

# Database (Supabase PostgreSQL)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT
JWT_SECRET=sua-chave-secreta-muito-segura-com-pelo-menos-32-caracteres
JWT_EXPIRES_IN=8h

# AWS S3
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_key
S3_BUCKET_NAME=nome-do-bucket

# Bitrix24
BITRIX_URL=https://sua-empresa.bitrix24.com.br
BITRIX_CLIENT_ID=seu_client_id
BITRIX_CLIENT_SECRET=seu_client_secret
BITRIX_REFRESH_TOKEN=seu_refresh_token

# Autentique
AUTENTIQUE_TOKEN=seu_token_autentique

# Logs
LOG_LEVEL=debug
